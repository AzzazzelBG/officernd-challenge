# Copy this file to ".env" (which is gitignored) before running the tests:
#   cp .env.example .env
#
# The values below are the throwaway staging credentials provided in the
# assignment, so the suite runs out of the box. In a real project these would
# be injected by the CI secret store and never committed.

# Base URL of the environment under test.
BASE_URL=https://staging.officernd.com

# Organization slug used in the /admin/<slug>/... routes.
ORG_SLUG=adrinkov-qa-task

# Credentials for the automation user.
USER_EMAIL=automation@adrinkov.user
USER_PASSWORD=P@ssw0rd
